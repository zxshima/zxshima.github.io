                                                                                                                                        "raw":  "Journal"
                                                                                                                                    },
                                                                                                                          "author":  "Unknown",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"Seize one ghast tear, a spider\u0027s eye,\\nAdd a second fermented, lest you die.\\nBrew it with glowstone dust, bright as the moon,\\nAnd a golden carrot, harvested soon.\\n\"}",
                                                                                                                                        "{\"text\":\"Add dragon\u0027s breath, but do not breath in,\\nIt is not for the weak, nor the foolhardy kin.\\nA potion of strength, to give you might,\\nAnd a potion of swiftness, for quickened flight.\\n\"}",
                                                                                                                                        "{\"text\":\"Stir it well, with a blaze rod\u0027s vigor,\\nAn effect you desire, drink to trigger.\\nThis brew is not for the faint of heart,\\nBut for the sister who seeks true arcane art.\\n\"}"
                                                                                                                                    ]
                                                                                                                      }
